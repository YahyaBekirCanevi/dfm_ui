{
  "name": "dfm-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*' && bun -e \"await Bun.write('dist/occt-import-js.wasm', Bun.file('node_modules/occt-import-js/dist/occt-import-js.wasm'))\"",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "occt-import-js": "^0.0.23",
    "three": "^0.171.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/drei": "^9.108.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/bun": "latest"
  }
}
